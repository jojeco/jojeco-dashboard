# JojeCo Dashboard — Environment Configuration
# Copy this file to .env and fill in your values

# === Frontend (Vite build-time) ===
VITE_API_URL=/api

# === Backend (Express runtime) ===
JWT_SECRET=generate-a-secure-random-string-here
NETDATA_URL=http://netdata:19999
NETDATA_CLAIM_TOKEN=

# === qBittorrent ===
QBT_URL=http://your-server:9091
QBT_USER=admin
QBT_PASS=your-password

# === Sonarr ===
SONARR_URL=http://your-server:8989
SONARR_KEY=your-sonarr-api-key

# === Radarr ===
RADARR_URL=http://your-server:7878
RADARR_KEY=your-radarr-api-key
