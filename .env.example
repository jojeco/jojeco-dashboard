# JojeCo Dashboard Environment Configuration
# Copy this file to .env and fill in your values

# === Frontend (Vite build-time) ===
VITE_API_URL=http://localhost:3001/api

# === Backend (Express runtime) ===
JWT_SECRET=change-me-to-a-random-string
NETDATA_URL=http://netdata:19999

# === Database ===
# SQLite database is stored at server/data/dashboard.db
# No configuration needed — auto-created on first run
