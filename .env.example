# Firebase Configuration
# Get these from your Firebase project settings: https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# API Configuration
# The URL where your backend API is running
VITE_API_URL=http://localhost:3001/api

# Backend JWT Secret
# IMPORTANT: Generate a secure random string for production
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-string-at-least-32-characters-long

# Netdata Configuration (optional)
# If you want to claim your Netdata instance to Netdata Cloud
NETDATA_CLAIM_TOKEN=
