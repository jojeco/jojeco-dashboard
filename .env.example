# JojeCo Dashboard — Environment Configuration
# Copy this file to .env and fill in your values

# === Frontend (Vite build-time) ===
VITE_API_URL=/api

# === Backend (Express runtime) ===
JWT_SECRET=generate-a-secure-random-string-here
NETDATA_URL=http://netdata:19999
NETDATA_CLAIM_TOKEN=

# === qBittorrent ===
QBT_URL=http://your-server:9091
QBT_USER=admin
QBT_PASS=your-password

# === Sonarr ===
SONARR_URL=http://your-server:8989
SONARR_KEY=your-sonarr-api-key

# === Radarr ===
RADARR_URL=http://your-server:7878
RADARR_KEY=your-radarr-api-key

# === Tautulli (Plex session monitor) ===
TAUTULLI_URL=http://192.168.50.13:8181
TAUTULLI_API_KEY=your-tautulli-api-key

# === Kiosk (/kiosk route — Galaxy Tab wall display) ===
# Frontend (Vite build-time)
VITE_KIOSK_REFRESH_MS=30000          # Auto-refresh interval in ms (default: 30000)
VITE_LITELLM_SPEND_CAP=20            # Monthly spend cap in USD for progress bar

# Backend (server-side proxies to avoid CORS / keep secrets off browser)
KIOSK_UPTIME_KUMA_URL=http://192.168.50.30:3001
KIOSK_GRAFANA_URL=http://192.168.50.13:3002
KIOSK_GRAFANA_USER=admin
KIOSK_GRAFANA_PASS=your-grafana-password
KIOSK_PI_AP_IP=192.168.50.31
